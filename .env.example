# =============================================================================
# Gemini Video Voiceover Translator — Environment configuration
# =============================================================================
# Authentication is via Application Default Credentials (ADC). Run
# `gcloud auth application-default login` locally; in Cloud Run the
# attached service account is used automatically. No API key required.
# =============================================================================

# ----- Google Cloud (REQUIRED for Vertex AI: Gemini + Cloud TTS) -------------
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# ----- Flask -----------------------------------------------------------------
FLASK_SECRET_KEY=change-me-in-production
FLASK_DEBUG=False
FLASK_PORT=8080

# ----- File processing -------------------------------------------------------
MAX_FILE_SIZE_MB=500
UPLOAD_FOLDER=static/uploads
TEMP_FOLDER=static/temp
OUTPUT_FOLDER=static/outputs
MAX_CONCURRENT_JOBS=3            # Currently informational; not yet enforced.
CLEANUP_TEMP_FILES_HOURS=24

# Background worker waits this long for the user to approve the translation
# before failing the job. Cloud Run --timeout should be >= this value.
REVIEW_TIMEOUT_SEC=1800          # 30 minutes

# ----- Storage backend -------------------------------------------------------
STORAGE_BACKEND=gcs              # Options: local, gcs
GCS_BUCKET_NAME=your-gcs-bucket
GCS_ENABLE_LIFECYCLE=True
GCS_TEMP_FILE_RETENTION_DAYS=7

# ----- Gemini models (Vertex AI) ---------------------------------------------
TRANSCRIPTION_MODEL=gemini-2.5-flash
TRANSLATION_MODEL=gemini-2.5-flash
GEMINI_TTS_MODEL=gemini-2.5-flash-tts

# ----- TTS backend & voices --------------------------------------------------
TTS_BACKEND=gemini               # Options: gemini, chirp3
TTS_SPEAKING_RATE=1.0            # Range 0.25 - 2.0 (Cloud TTS only)

# Number of concurrent TTS synth calls. 5 gives ~5x speedup against the old
# serial loop without tripping Vertex quotas (typical 100-300 RPM).
TTS_PARALLEL_WORKERS=5

# ----- TTS rate limiting & batching (legacy knobs, mostly informational) -----
TTS_BATCH_SIZE=10
TTS_MAX_TEXT_LENGTH=2000
TTS_RATE_LIMIT_DELAY=6.5
TTS_MAX_RETRIES=5
TTS_ENABLE_BATCHING=True

# ----- Audio synchronisation -------------------------------------------------
ENABLE_AUDIO_SYNC=True
MAX_TIMING_DIFFERENCE_SEC=0.5
SYNC_METHOD=stretch              # Options: stretch, pad, trim, tempo_only
PRESERVE_TOTAL_DURATION=True

# Duration enforcement loop: after first TTS pass, segments overrunning
# their slot are re-translated shorter (and re-synthesised) up to N times.
ENFORCE_ORIGINAL_DURATION=True
DURATION_TOLERANCE_SEC=1.0
MAX_DURATION_ADJUSTMENT_ATTEMPTS=3
ALLOW_TEXT_SHORTENING=True
MIN_SPEAKING_RATE=0.85           # 85% speed
MAX_SPEAKING_RATE=1.15           # 115% speed

# ----- Final video audio encoding (mux step) ---------------------------------
OUTPUT_AUDIO_BITRATE=192k
OUTPUT_AUDIO_SAMPLE_RATE=48000
OUTPUT_AUDIO_CHANNELS=2

# ----- Loudness normalisation (single-pass, applied to concatenated track) ---
ENABLE_LOUDNORM=True
LOUDNORM_TARGET_I=-16            # Integrated loudness target (LUFS)
LOUDNORM_TP=-1.5                 # True peak ceiling (dBTP)
LOUDNORM_LRA=11                  # Loudness range
