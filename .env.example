# Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# Flask Configuration
FLASK_SECRET_KEY=your_secret_key_here
FLASK_DEBUG=True
FLASK_PORT=5000

# File Processing Configuration
MAX_FILE_SIZE_MB=500
UPLOAD_FOLDER=static/uploads
TEMP_FOLDER=static/temp
OUTPUT_FOLDER=static/outputs

# Processing Configuration
MAX_CONCURRENT_JOBS=3
CLEANUP_TEMP_FILES_HOURS=24

# Gemini Model Configuration
TRANSCRIPTION_MODEL=gemini-2.5-flash
TRANSLATION_MODEL=gemini-2.5-flash
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts

# Google Cloud Configuration (Optional - only needed for GCS storage)
GOOGLE_CLOUD_PROJECT=your_google_cloud_project_id
GCS_BUCKET_NAME=your_gcs_bucket_name

# TTS Configuration
TTS_BACKEND=gemini  # Options: gemini, google_cloud
TTS_SPEAKING_RATE=1.0

# Audio Synchronization Configuration
ENABLE_AUDIO_SYNC=True
MAX_TIMING_DIFFERENCE_SEC=0.5
SYNC_METHOD=stretch  # Options: stretch, pad, trim

# TTS Rate Limiting & Batching Configuration
TTS_BATCH_SIZE=10  # Number of segments per API call
TTS_MAX_TEXT_LENGTH=2000  # Max characters per batch
TTS_RATE_LIMIT_DELAY=6.5  # Delay between batches (seconds)
TTS_MAX_RETRIES=5  # Max retry attempts for rate limiting
TTS_ENABLE_BATCHING=True  # Enable segment batching

# Storage Configuration
STORAGE_BACKEND=gcs  # Options: local, gcs
GCS_ENABLE_LIFECYCLE=True
GCS_TEMP_FILE_RETENTION_DAYS=7
